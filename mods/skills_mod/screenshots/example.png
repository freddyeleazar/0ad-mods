<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <!-- Fondo -->
  <rect width="800" height="600" fill="#0a0a0a"/>
  
  <!-- Estrellas de fondo -->
  <circle cx="50" cy="50" r="1" fill="#ffffff"/>
  <circle cx="150" cy="80" r="1.5" fill="#ffffff"/>
  <circle cx="250" cy="30" r="2" fill="#ffffff"/>
  <circle cx="350" cy="70" r="1" fill="#ffffff"/>
  <circle cx="450" cy="40" r="1.5" fill="#ffffff"/>
  <circle cx="550" cy="90" r="2" fill="#ffffff"/>
  <circle cx="650" cy="60" r="1" fill="#ffffff"/>
  <circle cx="750" cy="80" r="1.5" fill="#ffffff"/>
  
  <!-- Espada cruzada -->
  <rect x="380" y="100" width="40" height="300" fill="#c0c0c0" rx="5"/>
  <rect x="300" y="200" width="200" height="30" fill="#c0c0c0" rx="5"/>
  <rect x="380" y="100" width="40" height="20" fill="#ffd700"/>
  <rect x="300" y="200" width="200" height="30" fill="#ffd700"/>
  
  <!-- Escudo -->
  <circle cx="400" cy="350" r="80" fill="#8B4513" stroke="#ffd700" stroke-width="5"/>
  <circle cx="400" cy="350" r="60" fill="#A0522D"/>
  
  <!-- Estrella de experiencia -->
  <polygon points="400,320 410,340 430,340 415,350 420,370 400,360 380,370 385,350 370,340 390,340" fill="#ffd700"/>
  
  <!-- Niveles -->
  <rect x="100" y="500" width="600" height="20" fill="#333" rx="10"/>
  <rect x="100" y="500" width="400" height="20" fill="#ffd700" rx="10"/>
  <text x="400" y="515" font-family="Arial, sans-serif" font-size="14" fill="#000000" text-anchor="middle" font-weight="bold">Nivel 4 de 6</text>
  
  <!-- Estadísticas -->
  <text x="150" y="180" font-family="Arial, sans-serif" font-size="24" fill="#ffd700" text-anchor="middle">⚔️ +25% Daño</text>
  <text x="650" y="180" font-family="Arial, sans-serif" font-size="24" fill="#ffd700" text-anchor="middle">🛡️ +40% Vida</text>
  <text x="150" y="420" font-family="Arial, sans-serif" font-size="24" fill="#ffd700" text-anchor="middle">⚡ +30% Velocidad</text>
  <text x="650" y="420" font-family="Arial, sans-serif" font-size="24" fill="#ffd700" text-anchor="middle">💰 +20% Recolección</text>
  
  <!-- Texto -->
  <text x="400" y="560" font-family="Arial, sans-serif" font-size="48" fill="#ffd700" text-anchor="middle" font-weight="bold">Experience Skills</text>
  <text x="400" y="590" font-family="Arial, sans-serif" font-size="24" fill="#ffffff" text-anchor="middle">Mod para 0 A.D.</text>
  
  <!-- Decoraciones de borde -->
  <rect x="10" y="10" width="780" height="580" fill="none" stroke="#ffd700" stroke-width="2" rx="10"/>
  <rect x="20" y="20" width="760" height="560" fill="none" stroke="#ffd700" stroke-width="1" rx="5"/>
</svg>